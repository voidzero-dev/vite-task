  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "hello": "echo Hello, Vite Task Monorepo!",
