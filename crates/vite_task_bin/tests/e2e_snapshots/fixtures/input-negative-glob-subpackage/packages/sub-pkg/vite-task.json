      "input": ["../shared/**", "!../shared/dist/**"],
      "cache": true
    },
    "dotdot-auto-negative": {
      "command": "print-file ../shared/src/utils.ts ../shared/dist/output.js",
      "input": [{ "auto": true }, "!../shared/dist/**"],
      "cache": true
    }
  }
